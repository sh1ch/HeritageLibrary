<UserControl x:Class="Heritage.Wpf.Controls.TimePicker"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Heritage.Wpf.Controls"
             mc:Ignorable="d"
             x:Name="Root">
    <Border CornerRadius="5"
            BorderBrush="#26000000"
            BorderThickness="1">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition MinWidth="80" />
                <ColumnDefinition Width="1" />
                <ColumnDefinition MinWidth="80" />
                <ColumnDefinition Width="1" />
                <ColumnDefinition Width="*" MinWidth="60" />
            </Grid.ColumnDefinitions>

            <ComboBox
                Grid.Column="0"
                ItemsSource="{Binding Hours, ElementName=Root}"
                SelectedItem="{Binding SelectedHour, ElementName=Root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                BorderThickness="0"
                Background="Transparent"
                VerticalContentAlignment="Center" />

            <Border
                Grid.Column="1"
                Margin="0"
                Background="#26000000" />

            <ComboBox
                Grid.Column="2"
                ItemsSource="{Binding Minutes, ElementName=Root}"
                SelectedItem="{Binding SelectedMinute, ElementName=Root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                BorderThickness="0"
                Background="Transparent"
                VerticalContentAlignment="Center" />

            <Border
                Grid.Column="3"
                Margin="0"
                Background="#26000000" />

            <ComboBox
                Grid.Column="4"
                ItemsSource="{Binding Periods, ElementName=Root}"
                SelectedItem="{Binding SelectedPeriod, ElementName=Root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                BorderThickness="0"
                Background="Transparent"
                VerticalContentAlignment="Center"
                Visibility="{Binding PeriodVisibility, ElementName=Root}" />

        </Grid>
    </Border>
</UserControl>
